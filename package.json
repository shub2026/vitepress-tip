{
  "name": "vitepress-tip",
  "version": "1.0.0",
  "description": "基于 VitePress 的极简风格知识分享平台",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/shub2026/vitepress-tip"
  },
  "keywords": ["vitepress", "docs", "blog", "knowledge"],
  "author": "shub2026",
  "license": "MIT",
  "scripts": {
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "format": "prettier --write \"docs/**/*.{md,ts,css}\"",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf docs/.vitepress/dist docs/.vitepress/cache"
  },
  "devDependencies": {
    "mermaid": "^11.13.0",
    "prettier": "^3.3.0",
    "prettier-plugin-sh": "^0.18.1",
    "vitepress": "^1.6.4",
    "vitepress-plugin-mermaid": "^2.0.17",
    "vue": "^3.5.30"
  }
}
